# ─── Water Network Simulator — Environment Configuration ───────────────────
# Copy this file to .env and adjust values as needed.
# All values shown are the defaults used when the variable is not set.

# ── Port bindings ──────────────────────────────────────────────────────────
BACKEND_PORT=8000          # host port for the FastAPI backend
FRONTEND_PORT=3001         # host port for the Nginx frontend

# ── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the backend.
# In production, restrict this to your actual domain.
CORS_ORIGINS=http://localhost:3001,http://localhost:5173

# ── Frontend build ─────────────────────────────────────────────────────────
# The URL the React app uses to reach the API.
# In Docker: /api is proxied by Nginx → backend:8000 (leave as /api).
# For local dev (npm run dev): leave empty — Vite proxy handles it.
VITE_API_URL=/api

# ── Solver tuning (optional overrides) ────────────────────────────────────
# These are the defaults baked into SolverConfig; override here if needed.
# SOLVER_MAX_ITERATIONS=100
# SOLVER_TOLERANCE_ABS=1e-6
# SOLVER_MAX_RECOVERY_ATTEMPTS=3

# ── AI Analysis (optional) ─────────────────────────────────────────────────
# Get a free key at https://console.groq.com — enables AI recommendations tab.
GROQ_API_KEY=
